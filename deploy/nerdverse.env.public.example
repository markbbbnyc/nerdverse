# nerdverse.env — PUBLIC SERVER (not your local Life 2 save)
# Copy to /opt/nerdverse-public/nerdverse.env on the Ubuntu host.

DB_USER=nerdverse
DB_NAME=nerdverse_public
DB_HOST=localhost

# Set a strong password on production; grant nerdverse-play read via group perms.
DB_PASS=CHANGE_ME_STRONG_PASSWORD

DB_SETUP_USER=root
# DB_SETUP_PASS=

# Public terminal lane — session DBs are nerdverse_web_{hex} under /var/lib/nerdverse/sessions/
NERDVERSE_DB_PREFIX=nerdverse
NERDVERSE_INSTALL_ROOT=/opt/nerdverse-public
NERDVERSE_SESSION_ROOT=/var/lib/nerdverse/sessions