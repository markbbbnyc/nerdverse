# nerdverse.env — PUBLIC SERVER TEMPLATE (not your local Life-2 save)
#
# install-server.sh copies this to /opt/nerdverse-public/nerdverse.env on first
# install and auto-generates DB_PASS / DB_SETUP_PASS when CHANGE_ME placeholders remain.
#
# DB_NAME is the shared schema template only. Browser players never play here —
# each tab gets nerdverse_web_{hex} via deploy/sandbox/nerdverse-cage.sh.

DB_USER=nerdverse
DB_NAME=nerdverse_public
DB_HOST=localhost

DB_PASS=CHANGE_ME_STRONG_PASSWORD

# nerdverse_setup provisions isolated nerdverse_web_* databases from the cage.
DB_SETUP_USER=nerdverse_setup
DB_SETUP_PASS=CHANGE_ME_SETUP_PASSWORD

NERDVERSE_DB_PREFIX=nerdverse
NERDVERSE_INSTALL_ROOT=/opt/nerdverse-public
NERDVERSE_SESSION_ROOT=/var/lib/nerdverse/sessions