# Nerdverse ignores
saves/db/*.sql
saves/db/.last_backup_date
saves/active_db
saves/session_handoff.md
!saves/db/.gitkeep
saves/*.bak
logs/*.log
*.swp
.DS_Store

# Local config (never commit credentials or machine-specific settings)
nerdverse.env
*.env
!nerdverse.env.example

# Generated documentation artifacts
nerdverse-companion.pdf
nerdverse-companion.aux
nerdverse-companion.log
nerdverse-companion.out
nerdverse-companion.toc
nerdverse-companion.html.bak
