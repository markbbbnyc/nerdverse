# nerdverse.env.example
# Copy this file to nerdverse.env and customize for your system.
# This file is safe to commit. The real nerdverse.env is git-ignored.

# === Runtime Game Connection (dedicated low-privilege app user) ===
DB_USER=nerdverse
DB_NAME=nerdverse2
DB_HOST=localhost

# Leave DB_PASS empty to rely on Unix socket auth or your ~/.my.cnf
# DB_PASS=some-strong-password

# Optional
# DB_PORT=3306

# === Bootstrap / Setup (privileged account) ===
# Used only by bootstrap.sh to create the database and the dedicated app user.
# Can be your personal DB user (e.g. 'mark' or 'root') that has CREATE USER + GRANT rights.
# DB_SETUP_USER=root
# DB_SETUP_PASS=

